---
import Button from './Button.astro';

interface Props {
  headline: string;
  subheadline: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
  showLogo?: boolean;
}

const { 
  headline, 
  subheadline, 
  ctaText, 
  ctaHref, 
  secondaryText, 
  secondaryHref,
  showLogo = false 
} = Astro.props;
---

<section class="relative bg-gradient-to-b from-[var(--color-surface)] to-[var(--color-bg)] py-20 md:py-32">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {showLogo && (
      <div class="mb-8">
        <div class="inline-flex flex-col">
          <span class="text-4xl md:text-5xl font-semibold tracking-wide text-[var(--color-primary)]">PYTHIA</span>
          <span class="text-xl md:text-2xl font-light tracking-[0.3em] text-[var(--color-primary)] opacity-80">INSIGHTS</span>
        </div>
      </div>
    )}
    
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[var(--color-text)] mb-6 leading-tight">
      {headline}
    </h1>
    
    <p class="text-lg md:text-xl text-[var(--color-text-muted)] mb-10 max-w-2xl mx-auto">
      {subheadline}
    </p>
    
    {(ctaText || secondaryText) && (
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        {ctaText && ctaHref && (
          <Button href={ctaHref} size="lg">{ctaText}</Button>
        )}
        {secondaryText && secondaryHref && (
          <Button href={secondaryHref} variant="outline" size="lg">{secondaryText}</Button>
        )}
      </div>
    )}
  </div>
</section>
