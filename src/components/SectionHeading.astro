---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { label, title, subtitle, align = 'center', class: className = '' } = Astro.props;

const alignClasses = align === 'center' ? 'text-center' : 'text-left';
---

<div class:list={["mb-12", alignClasses, className]}>
  {label && (
    <span class="text-sm font-medium tracking-widest text-[var(--color-accent)] uppercase mb-2 block">
      {label}
    </span>
  )}
  <h2 class="text-3xl md:text-4xl font-semibold text-[var(--color-text)] mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
