---

<a href={href || '#'} class="group block bg-[var(--color-surface)] rounded-xl p-6 shadow-sm border border-[var(--color-border)] hover:shadow-md hover:border-[var(--color-primary)] transition-all duration-200">
  <div class="text-[var(--color-primary)] mb-4 group-hover:text-[var(--color-primary-light)] transition-colors">
    <Fragment set:html={icons[icon] || icons.calculator} />
  </div>
  <h3 class="text-xl font-semibold text-[var(--color-text)] mb-2 group-hover:text-[var(--color-primary)] transition-colors">
    {title}
  </h3>
  <p class="text-[var(--color-text-muted)]">
    {description}
  </p>
</a>
