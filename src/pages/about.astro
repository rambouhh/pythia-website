---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
---

<Layout title="About | Pythia Insights">
  <!-- Hero Section -->
  <Hero 
    headline="The Oracle for Modern Business"
    subheadline="Where ancient wisdom meets modern finance. We transform data into foresight."
  />

  <!-- The Pythia Story -->
  <section class="py-20 bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading 
        label="Our Story"
        title="Named for the Oracle of Delphi"
      />
      <div class="prose prose-lg max-w-none text-[var(--color-text-muted)]">
        <p class="mb-6">
          In ancient Greece, the Pythia was the high priestess of the Temple of Apollo at Delphi—the most powerful oracle in the classical world. Leaders, kings, and entrepreneurs traveled from across the known world to seek her counsel before making critical decisions.
        </p>
        <p class="mb-6">
          The Pythia didn't just predict the future—she helped people see clearly by cutting through complexity and revealing the truth hidden in plain sight.
        </p>
        <p>
          That's exactly what we do with your financial data. In a world drowning in numbers, reports, and metrics, we help you see what matters. We transform raw data into strategic clarity, enabling you to make decisions with confidence.
        </p>
      </div>
    </div>
  </section>

  <!-- About Eric Section -->
  <section class="py-20 bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-12 items-start">
        <div class="md:col-span-1">
          <div class="w-48 h-48 mx-auto md:mx-0 rounded-full bg-[var(--color-primary)] opacity-20"></div>
        </div>
        <div class="md:col-span-2">
          <span class="text-sm font-medium tracking-widest text-[var(--color-accent)] uppercase mb-2 block">Founder</span>
          <h2 class="text-3xl font-semibold text-[var(--color-text)] mb-4">Eric Anderson</h2>
          <div class="text-[var(--color-text-muted)] space-y-4">
            <p>
              With over a decade of experience in finance leadership, Eric has been in the trenches with high-growth companies from seed stage through acquisition.
            </p>
            <p>
              His track record includes leading finance operations at VC and PE-backed companies, navigating explosive revenue growth, and guiding organizations through multiple successful exits, equity raises, and debt financings.
            </p>
            <p>
              Eric specializes in SaaS businesses and brings a rare combination of deep technical knowledge and hands-on operational expertise. He doesn't just understand the numbers—he understands what they mean for your business.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <span class="px-3 py-1 bg-[var(--color-primary)] bg-opacity-10 text-[var(--color-primary)] text-sm rounded-full">10+ Years Finance</span>
            <span class="px-3 py-1 bg-[var(--color-primary)] bg-opacity-10 text-[var(--color-primary)] text-sm rounded-full">SaaS Expert</span>
            <span class="px-3 py-1 bg-[var(--color-primary)] bg-opacity-10 text-[var(--color-primary)] text-sm rounded-full">M&A Experience</span>
            <span class="px-3 py-1 bg-[var(--color-primary)] bg-opacity-10 text-[var(--color-primary)] text-sm rounded-full">VC/PE Specialist</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach Section -->
  <section class="py-20 bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading 
        title="Our Approach"
        subtitle="How we deliver value to growing companies"
      />
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-[var(--color-bg)] rounded-xl p-8">
          <div class="w-12 h-12 bg-[var(--color-primary)] bg-opacity-10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--color-text)] mb-3">Value-Based</h3>
          <p class="text-[var(--color-text-muted)]">
            We focus on delivering measurable value, not just completing tasks. Every engagement is structured around outcomes that matter to your business.
          </p>
        </div>
        
        <div class="bg-[var(--color-bg)] rounded-xl p-8">
          <div class="w-12 h-12 bg-[var(--color-primary)] bg-opacity-10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--color-text)] mb-3">Tech-Forward</h3>
          <p class="text-[var(--color-text-muted)]">
            We leverage AI and automation to handle routine tasks, freeing us to focus on strategic analysis and high-value advisory work.
          </p>
        </div>
        
        <div class="bg-[var(--color-bg)] rounded-xl p-8">
          <div class="w-12 h-12 bg-[var(--color-primary)] bg-opacity-10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--color-text)] mb-3">Full-Stack</h3>
          <p class="text-[var(--color-text-muted)]">
            From daily bookkeeping to board-level strategy, we cover the entire finance function so you have one partner who sees the whole picture.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-[var(--color-bg)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold text-[var(--color-text)] mb-4">
        Let's work together
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] mb-8">
        Ready to bring clarity to your financial operations? We'd love to hear from you.
      </p>
      <Button href="/contact" size="lg">Get in Touch</Button>
    </div>
  </section>
</Layout>
