---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Contact | Pythia Insights">
  <!-- Hero Section -->
  <Hero 
    headline="Let's Talk"
    subheadline="Ready to bring clarity to your financial operations? We'd love to hear from you."
  />

  <!-- Contact Section -->
  <section class="py-20 bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12">
        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-semibold text-[var(--color-text)] mb-6">Send us a message</h2>
          <ContactForm />
        </div>
        
        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <div class="bg-[var(--color-bg)] rounded-xl p-8 sticky top-24">
            <h2 class="text-2xl font-semibold text-[var(--color-text)] mb-6">Contact Info</h2>
            
            <div class="space-y-6">
              <div>
                <h3 class="font-medium text-[var(--color-text)] mb-2">Email</h3>
                <a href="mailto:hello@pythiainsights.com" class="text-[var(--color-primary)] hover:text-[var(--color-primary-light)] transition-colors">
                  hello@pythiainsights.com
                </a>
              </div>
              
              <div>
                <h3 class="font-medium text-[var(--color-text)] mb-2">Location</h3>
                <p class="text-[var(--color-text-muted)]">United States</p>
              </div>
              
              <div class="pt-6 border-t border-[var(--color-border)]">
                <h3 class="font-medium text-[var(--color-text)] mb-2">Response Time</h3>
                <p class="text-[var(--color-text-muted)]">
                  We typically respond within 24 hours during business days.
                </p>
              </div>
            </div>
            
            <div class="mt-8 p-4 bg-[var(--color-primary)] bg-opacity-5 rounded-lg">
              <p class="text-sm text-[var(--color-text-muted)]">
                <span class="font-medium text-[var(--color-text)]">Response time:</span> We typically respond within one business day.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
