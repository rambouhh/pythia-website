---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';

const services = [
  {
    id: 'accounting',
    title: 'Accounting & Bookkeeping',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm2.25-2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zM8.25 6h7.5v2.25H8.25V6zM4.5 19.5A2.25 2.25 0 006.75 21h10.5a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0017.25 4.5h-10.5A2.25 2.25 0 004.5 6.75v12.75z" /></svg>`,
    description: 'Real-time financials that tell your business story. We go beyond data entry to deliver financial clarity that powers decision-making.',
    details: 'Your books aren\'t just a compliance requirement—they\'re a strategic asset. We maintain your financials with precision and purpose, ensuring you always know where you stand.',
    includes: [
      'Full-service bookkeeping with GAAP compliance',
      'Monthly close within 10 business days',
      'Real-time financial dashboards',
      'Revenue recognition and deferred revenue tracking',
      'Accounts payable and receivable management',
      'Bank and credit card reconciliations',
      'Multi-entity and multi-currency support'
    ]
  },
  {
    id: 'payroll',
    title: 'Payroll Services',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
    description: 'Automated payroll that just works. Your team gets paid accurately and on time, every time.',
    details: 'Payroll is where errors hurt the most—your people. We handle the complexity so you can focus on building your team.',
    includes: [
      'Full-service payroll processing',
      'Federal, state, and local tax filings',
      'Direct deposit and payment management',
      'Benefits administration support',
      'Contractor payments and 1099 processing',
      'PTO tracking and management',
      'Workers\' compensation support'
    ]
  },
  {
    id: 'tax',
    title: 'Tax Planning & Preparation',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    description: 'Strategic tax planning, not just compliance. We minimize your tax burden while keeping you completely compliant.',
    details: 'Tax strategy isn\'t just about April—it\'s year-round planning that saves real money. We think proactively so you keep more of what you earn.',
    includes: [
      'Federal and state corporate tax returns',
      'Quarterly estimated tax planning',
      'R&D tax credit analysis and documentation',
      'State nexus analysis and compliance',
      'Entity structure optimization',
      'Tax provision and ASC 740 support',
      'Audit support and representation'
    ]
  },
  {
    id: 'advisory',
    title: 'CFO Advisory',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>`,
    description: 'Fractional CFO services for growing companies. Strategic financial leadership without the full-time commitment.',
    details: 'You need strategic financial guidance, but maybe not a full-time CFO. We bring executive-level expertise at a fraction of the cost.',
    includes: [
      'Financial strategy and planning',
      'Board and investor reporting',
      'Fundraising support and financial modeling',
      'KPI development and tracking',
      'Cash flow forecasting and management',
      'M&A due diligence and support',
      'Financial process optimization'
    ]
  },
  {
    id: 'intelligence',
    title: 'Business Intelligence',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`,
    description: 'Custom dashboards that drive decisions. Transform your data into actionable insights.',
    details: 'Data is only valuable if you can use it. We build dashboards and reports that surface the metrics that matter most to your business.',
    includes: [
      'Custom financial dashboards',
      'SaaS metrics tracking (MRR, ARR, churn, LTV)',
      'Cohort analysis and revenue analytics',
      'Automated reporting and alerts',
      'Data integration from multiple sources',
      'Budget vs. actual variance reporting',
      'Scenario modeling and forecasting'
    ]
  }
];

const tiers = [
  {
    name: 'Essentials',
    description: 'For early-stage companies building their foundation',
    features: [
      'Monthly bookkeeping',
      'Quarterly tax prep',
      'Basic reporting',
      'Email support'
    ]
  },
  {
    name: 'Growth',
    description: 'For scaling companies ready to level up',
    features: [
      'Everything in Essentials',
      'Payroll management',
      'Monthly advisory call',
      'Custom dashboards'
    ],
    featured: true
  },
  {
    name: 'Strategic',
    description: 'For companies preparing for their next milestone',
    features: [
      'Everything in Growth',
      'Fractional CFO partnership',
      'Board/investor reporting',
      'Full BI suite',
      'Priority support'
    ]
  }
];
---

<Layout title="Services | Pythia Insights">
  <!-- Hero Section -->
  <Hero 
    headline="Full-Stack Finance Services"
    subheadline="Comprehensive financial solutions designed for growing companies. From bookkeeping to boardroom strategy."
  />

  <!-- Services Sections -->
  {services.map((service, index) => (
    <section id={service.id} class:list={["py-20", index % 2 === 0 ? "bg-[var(--color-surface)]" : "bg-[var(--color-bg)]"]}>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-start gap-6 mb-8">
          <div class="text-[var(--color-primary)] flex-shrink-0">
            <Fragment set:html={service.icon} />
          </div>
          <div>
            <h2 class="text-3xl font-semibold text-[var(--color-text)] mb-4">{service.title}</h2>
            <p class="text-xl text-[var(--color-primary)] mb-4">{service.description}</p>
            <p class="text-[var(--color-text-muted)] mb-6">{service.details}</p>
          </div>
        </div>
        
        <div class="bg-[var(--color-bg)] rounded-xl p-6 border border-[var(--color-border)]">
          <h3 class="font-semibold text-[var(--color-text)] mb-4">What's included:</h3>
          <ul class="grid md:grid-cols-2 gap-3">
            {service.includes.map(item => (
              <li class="flex items-start gap-2 text-[var(--color-text-muted)]">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-accent)] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        
        <div class="mt-8">
          <Button href="/contact" variant="outline">Discuss This Service</Button>
        </div>
      </div>
    </section>
  ))}

  <!-- Service Tiers Section -->
  <section class="py-20 bg-[var(--color-primary)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-semibold text-white mb-4">Service Tiers</h2>
        <p class="text-lg text-white/80">Choose the level of support that fits your needs</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        {tiers.map(tier => (
          <div class:list={[
            "rounded-xl p-8",
            tier.featured 
              ? "bg-white ring-4 ring-[var(--color-accent)]" 
              : "bg-white/10 backdrop-blur"
          ]}>
            <h3 class:list={[
              "text-2xl font-semibold mb-2",
              tier.featured ? "text-[var(--color-primary)]" : "text-white"
            ]}>
              {tier.name}
            </h3>
            <p class:list={[
              "text-sm mb-6",
              tier.featured ? "text-[var(--color-text-muted)]" : "text-white/70"
            ]}>
              {tier.description}
            </p>
            <ul class="space-y-3">
              {tier.features.map(feature => (
                <li class:list={[
                  "flex items-center gap-2",
                  tier.featured ? "text-[var(--color-text)]" : "text-white"
                ]}>
                  <svg xmlns="http://www.w3.org/2000/svg" class:list={[
                    "w-5 h-5 flex-shrink-0",
                    tier.featured ? "text-[var(--color-accent)]" : "text-[var(--color-accent)]"
                  ]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      
      <div class="text-center mt-12">
        <p class="text-white/80 mb-6">Pricing tailored to your business. Let's find the right fit.</p>
        <Button href="/contact" variant="secondary" size="lg">Schedule a Consultation</Button>
      </div>
    </div>
  </section>
</Layout>
